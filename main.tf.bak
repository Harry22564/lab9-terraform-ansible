terraform {
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
  }
}

provider "azurerm" {
  features {}
  subscription_id = "081e00e6-d6d3-48f4-86a4-d039c379c3c9"
  resource_provider_registrations = "none"
}

resource "azurerm_resource_group" "lab9" {
  name     = "LAB9-RG"
  location = "francecentral"
}
